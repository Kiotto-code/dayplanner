type UpdateSlotArgs = 
 record {
   category: SlotCategory;
   description: text;
   endTime: int;
   id: SlotId;
   startTime: int;
   title: text;
 };
type TimeSlotView = 
 record {
   category: SlotCategory;
   completed: bool;
   description: text;
   endTime: int;
   id: SlotId;
   startTime: int;
   title: text;
 };
type SlotId = nat;
type SlotCategory = 
 variant {
   personal;
   study;
   work;
 };
type CreateSlotArgs = 
 record {
   category: SlotCategory;
   description: text;
   endTime: int;
   startTime: int;
   title: text;
 };
service : {
  createSlot: (args: CreateSlotArgs) -> (TimeSlotView);
  deleteSlot: (id: SlotId) -> (bool);
  listSlots: () -> (vec TimeSlotView) query;
  toggleSlotComplete: (id: SlotId) -> (opt TimeSlotView);
  updateSlot: (args: UpdateSlotArgs) -> (opt TimeSlotView);
}
